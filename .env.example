# ============================================================
#  Variables de entorno para Pi-hole
#  Copia este archivo: cp .env.example .env
#  Luego edita .env con tus valores reales
# ============================================================

# Zona horaria (lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Bogota

# Contraseña del panel web de Pi-hole
# ¡¡ CAMBIA ESTO por una contraseña segura !!
WEBPASSWORD=cambiame_por_favor

# Servidores DNS upstream (separados por ;)
# Pi-hole reenvía a estos las consultas que no bloquea
# Opciones populares:
#   Cloudflare:  1.1.1.1;1.0.0.1
#   Google:      8.8.8.8;8.8.4.4
#   Quad9:       9.9.9.9;149.112.112.112
PIHOLE_DNS=1.1.1.1;8.8.8.8
